{
  "schemaVersion": 1,
  "id": "disguises",
  "version": "${version}",
  "name": "Disguises",
  "description": "Entity disguise mod for Fabric — disguise players and mobs as any entity type.",
  "authors": ["coffee"],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["com.coffee.disguises.DisguisesMod"],
    "client": ["com.coffee.disguises.client.DisguisesModClient"],
    "modmenu": ["com.coffee.disguises.client.compat.ModMenuApiImpl"],
    "disguises:vanish": []
  },
  "mixins": [
    "disguises.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-permissions-api-v0": "*"
  },
  "suggests": {
    "cloth-config2": "*",
    "modmenu": "*",
    "luckperms": "*"
  }
}
